{
  "name": "castaminofen-fullstack-starter",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write .",
    "prepare": "husky install"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.6.3",
    "tsx": "^4.19.3",
    "eslint": "^9.14.0",
    "@eslint/js": "^10.0.1",
    "typescript-eslint": "^8.14.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.3.1",
    "@types/node": "^22.10.1",
    "husky": "^9.1.0",
    "prisma": "^5.10.0"
  }
}
